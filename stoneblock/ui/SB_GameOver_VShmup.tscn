[gd_scene format=3 uid="uid://dwb4fg5pg35nm"]

[ext_resource type="PackedScene" path="res://stoneblock/ui/SB_HighScoreBoard.tscn" id="2_board"]

[sub_resource type="GDScript" id="GDScript_logic"]
script/source = "extends CanvasLayer

func set_results(score: int, combo: int):
	var score_label = get_node_or_null(\"Control/CenterContainer/VBox/ScoreBox/ScoreVal\")
	var combo_label = get_node_or_null(\"Control/CenterContainer/VBox/ScoreBox/ComboVal\")
	if score_label: score_label.text = \"SCORE FINAL : \" + str(score)
	if combo_label: combo_label.text = \"COMBO MAXIMUM : \" + str(combo)
	
	# Soumission au classement (Top 5)
	if SB_HighScores.instance:
		SB_HighScores.instance.submit_score(score)
	
	# Rafraîchissement du tableau
	var board = get_node_or_null(\"Control/CenterContainer/VBox/HighScoreBoard\")
	if board: board.refresh()

func _on_restart_pressed():
	print(\"[GAME OVER] Restart pressed\")
	if SB_Core.instance:
		SB_Core.instance.load_scene_async(get_tree().current_scene.scene_file_path)
	else:
		get_tree().reload_current_scene()

func _on_menu_pressed():
	print(\"[GAME OVER] Menu pressed\")
	if SB_Core.instance:
		SB_Core.instance.load_scene_async(\"res://demo/demo1/10_menu_principal.tscn\")
"

